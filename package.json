{
  "name": "xtb-testowanie-warsztat",
  "version": "1.0.0",
  "private": true,
  "description": "Repo szkoleniowe — Testowanie aplikacji frontendowych (Vue 3 + TS)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run server\"",
    "server": "tsx watch server/index.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@testing-library/user-event": "^14.6.1",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.3",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.0.1",
    "cors": "^2.8.5",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "express": "^4.21.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.4.9",
    "prettier": "3.8.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.9",
    "vitest": "^2.1.3",
    "vue-tsc": "^2.1.6",
    "ws": "^8.18.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
